{
  "name": "@diatonic/web",
  "version": "0.5.2",
  "description": "Interactive web app for discovering musical scales and chords using a visual piano",
  "author": "Vegard Egeland",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "check": "biome check .",
    "check:fix": "biome check . --write",
    "lint": "biome lint .",
    "lint:fix": "biome lint . --write",
    "format": "biome format .",
    "format:fix": "biome format . --write",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@diatonic/piano": "^0.4.0",
    "kamasi": "^0.3.0",
    "modern-normalize": "^3.0.1",
    "preact": "^10.29.1",
    "tone": "^15.1.22"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@preact/preset-vite": "^2.10.5",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/preact": "^3.2.4",
    "@testing-library/user-event": "^14.6.1",
    "@vitest/coverage-v8": "^4.1.3",
    "@vitest/ui": "^4.1.3",
    "happy-dom": "^20.8.9",
    "typescript": "^5.9.3",
    "vite": "^8.0.7",
    "vitest": "^4.1.3"
  },
  "overrides": {
    "react": "npm:@preact/compat",
    "react-dom": "npm:@preact/compat"
  }
}
